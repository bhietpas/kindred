{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/play/**",
              "ui_kits/mobile/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Spectral|Hanken Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Spectral, Hanken Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|src|size|ring|square|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: name, src, size, ring, square, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='ring'] > Literal[value!=/^(?:none|gm|active|drift)$/]",
        "message": "<Avatar> ring must be one of 'none' | 'gm' | 'active' | 'drift'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|dot|size|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, dot, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|public|gm|whisper|pending|resolved|harm|brass)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'public' | 'gm' | 'whisper' | 'pending' | 'resolved' | 'harm' | 'brass'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|outline|solid)$/]",
        "message": "<Badge> variant must be one of 'soft' | 'outline' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|iconRight|fullWidth|disabled|loading|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, iconRight, fullWidth, disabled, loading, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|accent|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'accent' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|glow|interactive|padding|as|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, glow, interactive, padding, as, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='glow'] > Literal[value!=/^(?:none|ember|drift)$/]",
        "message": "<Card> glow must be one of 'none' | 'ember' | 'drift'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DiceRoll'] > JSXAttribute > JSXIdentifier[name!=/^(?:notation|rolls|modifier|total|faces|label|style|key|ref|className|style|children)$/]",
        "message": "<DiceRoll> doesn't accept that prop. Declared props: notation, rolls, modifier, total, faces, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|placeholder|hint|error|multiline|rows|icon|type|disabled|id|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, value, onChange, placeholder, hint, error, multiline, rows, icon, type, disabled, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|id|style|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange, label, disabled, id, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TurnCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:author|role|scope|whisperTo|body|dice|when|turnNo|unread|style|key|ref|className|style|children)$/]",
        "message": "<TurnCard> doesn't accept that prop. Declared props: author, role, scope, whisperTo, body, dice, when, turnNo, unread, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TurnCard'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:player|gm)$/]",
        "message": "<TurnCard> role must be one of 'player' | 'gm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TurnCard'] > JSXAttribute[name.name='scope'] > Literal[value!=/^(?:public|gm|whisper)$/]",
        "message": "<TurnCard> scope must be one of 'public' | 'gm' | 'whisper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ZoneChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|distance|revealed|current|count|onClick|style|key|ref|className|style|children)$/]",
        "message": "<ZoneChip> doesn't accept that prop. Declared props: name, distance, revealed, current, count, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ZoneChip'] > JSXAttribute[name.name='distance'] > Literal[value!=/^(?:close|near|far|distant)$/]",
        "message": "<ZoneChip> distance must be one of 'close' | 'near' | 'far' | 'distant'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
